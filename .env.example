# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=EcoMind AI — Pakistan's Intelligent Waste Command Center

# Supabase (create a dedicated project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Maps (Maps JavaScript API)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GEMINI_API_KEY=your_gemini_api_key
# Primary model (legacy — use GEMINI_MODELS for multi-model pool)
GEMINI_MODEL=gemini-flash-latest
# Multi-model pool — auto-switches when a model is busy (429/503/quota)
GEMINI_MODELS=gemini-2.0-flash,gemini-2.5-flash,gemini-flash-latest
# Fallbacks if GEMINI_MODELS is not set
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-flash-latest
# Optional per-agent model override (comma-separated, tries in order)
# GEMINI_MODEL_INTENT=gemini-2.0-flash-lite,gemini-flash-latest
# GEMINI_MODEL_OCR=gemini-2.0-flash,gemini-2.5-flash
# Token caps per agent (lower = cheaper; defaults: intent 512, recommendation 1024)
# GEMINI_MAX_OUTPUT_TOKENS=1024
# GEMINI_MAX_OUTPUT_INTENT=512
# GEMINI_MAX_OUTPUT_RECOMMENDATION=1024

# Email (Resend) — report PDFs sent to citizen + authority inboxes after each report
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# Civic command (DigTech / hackathon theme pivot)
# emergency | services | social
CIVIC_PROMPT_PACK=emergency
# Authority inboxes — receive email when citizens submit reports (also used for escalation)
CIVIC_ALERT_EMAIL=your_alert_email@example.com
# Comma-separated emails allowed to access /authority portal
AUTHORITY_EMAIL_ALLOWLIST=your_authority_email@example.com
# Supabase auth redirect URL: http://localhost:3000/auth/callback
# Production: https://your-domain.vercel.app/auth/callback
