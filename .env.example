# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CivicAI — Pakistan Citizen Assistant

# Supabase (create a dedicated project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Maps (Maps JavaScript API)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-flash-latest
# Comma-separated fallbacks when primary model is overloaded or quota-limited
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-flash-latest

# Email (Resend) — report PDFs sent to user email after each report
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# Civic command (DigTech / hackathon theme pivot)
# emergency | services | social
CIVIC_PROMPT_PACK=emergency
# Optional: email for high/critical escalation (coordinator inbox)
CIVIC_ALERT_EMAIL=your_alert_email@example.com
# Supabase auth redirect URL: http://localhost:3000/auth/callback
# Production: https://your-domain.vercel.app/auth/callback
