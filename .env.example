# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AI Engineering Framework

# Supabase (create a dedicated project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Auth (Supabase dashboard → Authentication → URL configuration)
# Site URL: http://localhost:3000
# Redirect URL: http://localhost:3000/auth/callback

# n8n Cloud
N8N_WEBHOOK_URL=
# Optional shared secret sent as x-aef-webhook-secret header
N8N_WEBHOOK_SECRET=
